{
  "name": "nexacon-livechat-widget",
  "version": "1.0.6",
  "description": "Embeddable live chat widget for Nexacon — drop a single script tag into any website",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./widget": {
      "import": "./dist/widget.js",
      "types": "./dist/widget.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:widget",
    "build:lib": "esbuild src/core.ts --bundle --outfile=dist/index.js --format=esm --target=es2018",
    "build:widget": "esbuild src/index.ts --bundle --outfile=dist/widget.js --format=iife --global-name=NexaconChat --target=es2018",
    "build:min": "esbuild src/index.ts --bundle --outfile=dist/widget.min.js --format=iife --global-name=NexaconChat --target=es2018 --minify",
    "build:types": "tsc --emitDeclarationOnly",
    "build:all": "npm run build && npm run build:min && npm run build:types",
    "dev": "esbuild src/index.ts --bundle --outfile=dist/widget.js --format=iife --global-name=NexaconChat --target=es2018 --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nexacon",
    "live-chat",
    "widget",
    "embeddable",
    "chat",
    "support"
  ],
  "author": "Nexacon",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.2.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "strophe.js": "^4.0.0-rc0"
  }
}
